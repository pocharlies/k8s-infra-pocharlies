# Copy to a private shell env file outside Git, fill values from the secret
# manager, then source it before running scripts. Do not commit real values.

# OVH API
export OVH_ENDPOINT=ovh-eu
export OVH_APPLICATION_KEY=...
export OVH_APPLICATION_SECRET=...
export OVH_CONSUMER_KEY=...
export OVH_SUBSIDIARY=ES

# Alternate OVH account available through the cluster Secret:
# OVH_SECRET_NAME=ovh-ca scripts/with_ovh_env.sh -- <command>

# Cloudflare API
export CLOUDFLARE_API_TOKEN=...
export CLOUDFLARE_ZONE_ID=...

# Tailscale and SSH bootstrap
export TAILSCALE_AUTH_KEY=...
export SSH_PUBLIC_KEY='ssh-ed25519 ...'

# Existing topology
export DOMAIN=e-dani.com
export CURRENT_HOME_NODE_IP=100.83.56.98
export CURRENT_SAUVAGE_SERVER_NAME=...
export CURRENT_SAUVAGE_PUBLIC_IP=57.129.17.172

# k3s join values. Read K3S_TOKEN from the existing node or secret manager;
# never commit it or print it in logs.
export K3S_TOKEN=...
export K3S_JOIN_SERVER_IP=100.83.56.98

# Destructive/cost gates. Keep unset until the exact execution step.
# export CONFIRM_OVH_ORDER=order-3-ks5
# export CONFIRM_OVH_REINSTALL=install-ubuntu-24.04
# export CONFIRM_DEMOTE_X86=demote-x86-after-ks5-quorum
# export CONFIRM_DNS_TARGET_REWRITE=update-ha-targets
# export CONFIRM_CLOUDFLARE_RESTORE=restore-dns-from-backup
